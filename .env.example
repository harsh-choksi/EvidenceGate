# Required only for `pnpm demo:live` and `evidencegate sources check --approve`.
OPENAI_API_KEY=

# Live tests remain off in ordinary development and CI.
RUN_LIVE_OPENAI_TESTS=false

# Required only when using the adjudicator factory directly; `pnpm demo:live`
# supplies this explicit opt-in because the command itself is already a live action.
RUN_LIVE_OPENAI_ADJUDICATION=false

# Configurable product identity.
EVIDENCEGATE_PRODUCT_NAME=EvidenceGate
EVIDENCEGATE_TAGLINE=Verify AI-generated code against its requirements and the authoritative sources behind them.
